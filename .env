POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=medcore
POSTGRES_USER=medcore
POSTGRES_PASSWORD=medcore_secret
REDIS_HOST=redis
REDIS_PORT=6379
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=medcore
MINIO_USE_SSL=false
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/2
APP_NAME=MedCore KG
APP_ENV=development
APP_DEBUG=true
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:80","http://localhost:3000","http://localhost:4000"]
SENTRY_DSN=

# SMTP Email
# For Gmail: enable 2FA, create App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@medcore.kg
SMTP_FROM_NAME=MedCore KG
SMTP_USE_TLS=true

# Voice Assistant
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
WHISPER_MODEL_SIZE=base
VOICE_AI_TIMEOUT=5
VOICE_RATE_LIMIT=30
